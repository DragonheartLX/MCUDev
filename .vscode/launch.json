{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "STM32F4 Debug",
            "cwd": "${workspaceRoot}/build",
            "executable": "${command:cmake.launchTargetPath}",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "openocd",
            "configFiles": [
                "${workspaceRoot}/scripts/interface/cmsis-dap.cfg",
                "${workspaceRoot}/scripts/target/stm32f4x.cfg"
            ],
            "searchDir": [],
            "runToEntryPoint": "main",
            "showDevDebugOutput": "none"
        },
        {
            "name": "STM32F1 Debug",
            "cwd": "${workspaceRoot}/build",
            "executable": "${command:cmake.launchTargetPath}",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "openocd",
            "configFiles": [
                "${workspaceRoot}/scripts/interface/cmsis-dap.cfg",
                "${workspaceRoot}/scripts/target/stm32f1x.cfg"
            ],
            "searchDir": [],
            "runToEntryPoint": "main",
            "showDevDebugOutput": "none",
            "serverArgs": [
                "-c",
                "transport select swd"
            ]
        },
        {
            "type": "probe-rs-debug",
            "request": "launch",
            "name": "STM32F103RC",
            "cwd": "${workspaceRoot}/build",
            "speed": 10000,
            "runtimeExecutable": "probe-rs",
            "runtimeArgs": [
                "dap-server"
            ],
            "chip": "STM32F103RC",
            "flashingConfig": {
                "flashingEnabled": true,
                "haltAfterReset": false,
                "formatOptions": {
                    "binaryFormat": "hex"
                }
            },
            "coreConfigs": [
                {
                    "coreIndex": 0,
                    "programBinary": "${command:cmake.launchTargetPath}",
                }
            ],
            "env": {},
            "consoleLogLevel": "Console"
        }
    ]
}