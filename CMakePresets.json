{
    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "toolchainFile": "${sourceDir}/cmake/stm32-toolchain.cmake",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "Debug F407VGT6",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMSIS_Dvendor": "STMicroelectronics:13",
                "CMSIS_Dname": "STM32F407VGT6",
                "CMSIS_Dcore": "Cortex-M4",
                "CMSIS_Dtz": "NO_TZ",
                "CMSIS_Dfpu": "SP_FPU",
                "CMSIS_Ddsp": "DSP",
                "CMSIS_Dmve": "NO_MVE",
                "CMSIS_Dmpu": "MPU",
                "CMSIS_Dendian": "Little-endian",
                "CMSIS_Dsecure": "",
                "CMSIS_Tcompiler": "GCC"
            }
        },
        {
            "name": "Release F407VGT6",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMSIS_Dvendor": "STMicroelectronics:13",
                "CMSIS_Dname": "STM32F407VGT6",
                "CMSIS_Dcore": "Cortex-M4",
                "CMSIS_Dtz": "NO_TZ",
                "CMSIS_Dfpu": "SP_FPU",
                "CMSIS_Ddsp": "DSP",
                "CMSIS_Dmve": "NO_MVE",
                "CMSIS_Dmpu": "MPU",
                "CMSIS_Dendian": "Little-endian",
                "CMSIS_Dsecure": "",
                "CMSIS_Tcompiler": "GCC"
            }
        },
        {
            "name": "Debug F103RCT6",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMSIS_Dvendor": "STMicroelectronics:13",
                "CMSIS_Dname": "STM32F103RCT6",
                "CMSIS_Dcore": "Cortex-M3",
                "CMSIS_Dendian": "Little-endian",
                "CMSIS_Dsecure": "",
                "CMSIS_Tcompiler": "GCC"
            }
        },
        {
            "name": "Release F103RCT6",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMSIS_Dvendor": "STMicroelectronics:13",
                "CMSIS_Dname": "STM32F103RCT6",
                "CMSIS_Dcore": "Cortex-M3",
                "CMSIS_Dendian": "Little-endian",
                "CMSIS_Dsecure": "",
                "CMSIS_Tcompiler": "GCC"
            }
        }
